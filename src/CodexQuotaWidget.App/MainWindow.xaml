<Window x:Class="CodexQuotaWidget.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex 额度小窗"
        Width="620"
        Height="48"
        MinWidth="420"
        MinHeight="44"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="Card"
            Padding="13,9"
            CornerRadius="14"
            Background="#D3161B22"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">
        <Grid VerticalAlignment="Center">
            <TextBlock x:Name="TitleText"
                       Text=""
                       Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="QuotaLeft"
                           Text="未获取到额度"
                           Foreground="#F5F7FA"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="QuotaSeparator"
                           Text="｜"
                           Foreground="#99FFFFFF"
                           Margin="6,0" />
                <TextBlock x:Name="QuotaRight"
                           Text="--"
                           Foreground="#F5F7FA"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock x:Name="ResetLeft"
                           Text="重置 --"
                           Foreground="#C9D1D9"
                           Margin="18,0,0,0" />
                <TextBlock x:Name="ResetSeparator"
                           Text="｜"
                           Foreground="#7FFFFFFF"
                           Margin="6,0" />
                <TextBlock x:Name="ResetRight"
                           Text="--"
                           Foreground="#C9D1D9" />

                <TextBlock x:Name="RefreshLeft"
                           Text="下次 --"
                           Foreground="#AAB2BD"
                           Margin="18,0,0,0" />
                <TextBlock x:Name="RefreshSeparator"
                           Text="·"
                           Foreground="#7FFFFFFF"
                           Margin="6,0" />
                <TextBlock x:Name="RefreshRight"
                           Text="--"
                           Foreground="#AAB2BD" />
            </StackPanel>

            <Border x:Name="EditBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    CornerRadius="8"
                    Padding="6,1"
                    Background="#334A90E2"
                    Visibility="Collapsed">
                <TextBlock Text="编辑"
                           Foreground="#EAF3FF"
                           FontSize="10" />
            </Border>

            <Thumb x:Name="ResizeThumb"
                   Width="18"
                   Height="18"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,-7,-4"
                   Cursor="SizeNWSE"
                   Visibility="Collapsed"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="9"
                                Background="#CC4A90E2"
                                BorderBrush="#EAF3FF"
                                BorderThickness="1">
                            <Path Stroke="#EAF3FF"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 6 12 L 12 6 M 9 13 L 13 9" />
                        </Border>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
